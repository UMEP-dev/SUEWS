{
  "dxt_version": "0.1.0",
  "name": "SUEWS Assistant",
  "version": "1.0.0",
  "description": "AI-powered configuration guidance and result interpretation for the Surface Urban Energy and Water balance Scheme (SUEWS)",
  "author": {
    "name": "Ting Sun & Claude Code"
  },
  "server": {
    "command": "python",
    "args": ["-m", "suews_mcp.server"]
  },
  "tools": [
    {
      "name": "validate_suews_config",
      "description": "Check a SUEWS configuration file for scientific soundness and common errors",
      "inputSchema": {
        "type": "object",
        "properties": {
          "config_path": {
            "type": "string",
            "description": "Path to YAML configuration file"
          },
          "strict": {
            "type": "boolean",
            "description": "Whether to enforce all validation rules"
          }
        },
        "required": ["config_path"]
      }
    },
    {
      "name": "suggest_suews_parameters",
      "description": "Get parameter recommendations based on urban context and climate zone",
      "inputSchema": {
        "type": "object",
        "properties": {
          "partial_config": {
            "type": "string",
            "description": "Path to partial YAML configuration"
          },
          "context": {
            "type": "string",
            "description": "Urban context (city_centre, suburban, industrial, etc.)"
          },
          "climate_zone": {
            "type": "string",
            "description": "Climate classification"
          }
        },
        "required": ["partial_config"]
      }
    },
    {
      "name": "check_suews_physics_compatibility",
      "description": "Verify that selected physics methods work well together",
      "inputSchema": {
        "type": "object",
        "properties": {
          "methods": {
            "type": "object",
            "description": "Dictionary of method selections"
          }
        },
        "required": ["methods"]
      }
    },
    {
      "name": "generate_suews_template",
      "description": "Create a configuration template tailored to your site and research focus",
      "inputSchema": {
        "type": "object",
        "properties": {
          "site_type": {
            "type": "string",
            "description": "Type of urban site"
          },
          "research_focus": {
            "type": "string",
            "description": "Primary research interest"
          },
          "include_comments": {
            "type": "boolean",
            "description": "Whether to include explanatory comments"
          }
        },
        "required": ["site_type", "research_focus"]
      }
    },
    {
      "name": "explain_suews_parameter",
      "description": "Get detailed explanation of any SUEWS parameter with typical values",
      "inputSchema": {
        "type": "object",
        "properties": {
          "parameter_name": {
            "type": "string",
            "description": "Name of the parameter"
          },
          "include_examples": {
            "type": "boolean",
            "description": "Whether to include usage examples"
          }
        },
        "required": ["parameter_name"]
      }
    },
    {
      "name": "diagnose_suews_energy_balance",
      "description": "Analyze energy balance closure and identify potential issues",
      "inputSchema": {
        "type": "object",
        "properties": {
          "output_path": {
            "type": "string",
            "description": "Path to SUEWS output file"
          },
          "site_metadata": {
            "type": "object",
            "description": "Optional site information"
          }
        },
        "required": ["output_path"]
      }
    },
    {
      "name": "interpret_suews_thermal_comfort",
      "description": "Interpret thermal comfort metrics from SUEWS outputs",
      "inputSchema": {
        "type": "object",
        "properties": {
          "output_path": {
            "type": "string",
            "description": "Path to SUEWS output file"
          },
          "period": {
            "type": "string",
            "description": "Analysis period (full, summer, heatwave, etc.)"
          }
        },
        "required": ["output_path"]
      }
    },
    {
      "name": "analyze_suews_urban_effects",
      "description": "Examine urban heat island and other urban climate effects",
      "inputSchema": {
        "type": "object",
        "properties": {
          "output_path": {
            "type": "string",
            "description": "Path to SUEWS output file"
          },
          "rural_reference": {
            "type": "string",
            "description": "Optional rural reference data"
          }
        },
        "required": ["output_path"]
      }
    },
    {
      "name": "validate_suews_against_observations",
      "description": "Compare model results with measured data",
      "inputSchema": {
        "type": "object",
        "properties": {
          "model_output": {
            "type": "string",
            "description": "Path to SUEWS output"
          },
          "observations": {
            "type": "string",
            "description": "Path to observation data"
          },
          "variables": {
            "type": "array",
            "description": "Specific variables to validate",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["model_output", "observations"]
      }
    },
    {
      "name": "generate_suews_insights_report",
      "description": "Create comprehensive narrative report from simulation results",
      "inputSchema": {
        "type": "object",
        "properties": {
          "output_path": {
            "type": "string",
            "description": "Path to SUEWS output"
          },
          "config_path": {
            "type": "string",
            "description": "Path to configuration used"
          },
          "research_context": {
            "type": "string",
            "description": "Research questions and goals"
          }
        },
        "required": ["output_path", "config_path", "research_context"]
      }
    }
  ],
  "prompts": [
    {
      "name": "urban_climate_expert",
      "description": "Expert in urban climate modeling and SUEWS",
      "arguments": [
        {
          "name": "question",
          "description": "Your urban climate or SUEWS question",
          "required": true
        }
      ]
    },
    {
      "name": "config_wizard",
      "description": "Configuration setup wizard",
      "arguments": [
        {
          "name": "site_info",
          "description": "Information about your site and research goals",
          "required": true
        }
      ]
    },
    {
      "name": "result_interpreter",
      "description": "Results analysis expert",
      "arguments": [
        {
          "name": "output_info",
          "description": "Information about your SUEWS outputs to analyze",
          "required": true
        }
      ]
    }
  ]
}